# Repo-root .env — auto-loaded by docker compose for BOTH stacks.
# Copy to .env and fill in. Validate with: ./scripts/check-env.sh <dev|prod>
#
# Legend: [dev+prod] required by both · [prod] required for prod · [opt] optional

# ---- Auth / login (required by both stacks) ----
GOOGLE_CLIENT_ID=                 # [dev+prod] Google OAuth client id
GOOGLE_CLIENT_SECRET=             # [dev+prod] Google OAuth client secret
BOOTSTRAP_ADMIN_EMAILS=          # [dev+prod] comma-separated admin allowlist; without it nobody can log in
PLEX_TOKEN_ENC_KEY=              # [dev+prod] exactly 64 hex chars — `openssl rand -hex 32`

# ---- Better Auth ----
# dev: both have working defaults (localhost). prod: BOTH required.
BETTER_AUTH_SECRET=             # [prod] session/cookie signing secret — `openssl rand -hex 32`
BETTER_AUTH_URL=                # [prod] public origin, e.g. https://torrents.example.com (dev defaults to http://localhost:5173)

# ---- Transmission (prod) ----
# The backend reads PROD_* inside the container (it detects /.dockerenv).
PROD_TRANSMISSION_HOST=         # [prod] Transmission RPC host
PROD_TRANSMISSION_PORT=9091     # [prod] Transmission RPC port
PROD_TRANSMISSION_USERNAME=     # [opt] only if Transmission RPC auth is enabled
PROD_TRANSMISSION_PASSWORD=     # [opt] only if Transmission RPC auth is enabled

# ---- Transmission (dev) ----
# All have defaults in docker-compose.dev.yml; override only if needed.
DEV_TRANSMISSION_HOST=host.docker.internal   # [opt]
DEV_TRANSMISSION_PORT=9091                    # [opt]
DEV_TRANSMISSION_USERNAME=                    # [opt]
DEV_TRANSMISSION_PASSWORD=                    # [opt]
